generator client {
  provider = "prisma-client-js"
  output   = "../src/types/prisma"
}

datasource db {
  provider = "sqlite"
  // Overridable via DATABASE_URL (Electron / web server dataDir)
  url      = env("DATABASE_URL")
}

model Story {
  id         String      @id @default(cuid())
  title      String
  status     StoryStatus @default(DRAFT)
  exportPath String?
  /** Visual / tone bible for clip prompt continuity */
  styleNote  String?
  /** Art medium id (same catalog as Character.artStyle). */
  artStyle   String?
  /** Poster / list card cover (same role as Character.refImagePath). */
  coverPath  String?
  /** Optional multi cover gallery JSON (same shape as character gallery). */
  refGalleryJson String?
  /**
   * Hard rules for cover / clip generation (必須／禁止).
   * Highest user priority over styleNote / positive descriptions.
   */
  hardRules  String?
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt

  timeline        TimelineEntry[]
  storyCharacters StoryCharacter[]
  storyScenes     StoryScene[]
  storyProps      StoryProp[]
  storyActions    StoryAction[]
}

/** Global character library asset (not owned by a story). */
model Character {
  id             String  @id @default(cuid())
  name           String
  soulMdPath     String?
  description    String
  refImagePath   String?
  appearance     String?
  personality    String?
  backstory      String?
  costume        String?
  ageRange       String?
  gender         String?
  voiceDesc      String?
  /** JSON string array of BCP-47 / ISO language codes the character speaks */
  spokenLanguages String?
  mannerisms     String?
  relationships  String?
  visualTags     String?
  seedPrompt     String?
  /** 生成鐵則：必須／禁止（sheet、intro video 等最高優先） */
  hardRules      String?
  profileJson    String?
  refSheetPath   String?
  refGalleryJson String?
  soulHubId      Int?
  artStyle       String?
  /** @deprecated Prefer CharacterCostume M2M; kept for migration/fallback */
  costumesJson   String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  storyLinks      StoryCharacter[]
  timelineEntries TimelineEntry[]
  costumeLinks    CharacterCostume[]
}

/**
 * Global wardrobe asset (not owned by a single character).
 * May link to 0..N characters via CharacterCostume.
 */
model Costume {
  id             String   @id @default(cuid())
  name           String
  description    String
  artStyle       String?
  refImagePath   String?
  refGalleryJson String?
  seedPrompt     String?
  /** 生成鐵則：必須／禁止（換裝板、介紹片） */
  hardRules      String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  characterLinks CharacterCostume[]
  storyCasts     StoryCharacter[]
}

/** Character ↔ Costume many-to-many. */
model CharacterCostume {
  characterId      String
  costumeId        String
  sortOrder        Int     @default(0)
  /** Last “character wearing this costume” plate for this pair */
  dressedImagePath String?

  character Character @relation(fields: [characterId], references: [id], onDelete: Cascade)
  costume   Costume   @relation(fields: [costumeId], references: [id], onDelete: Cascade)

  @@id([characterId, costumeId])
}

/** Global scene / location library asset. */
model Scene {
  id             String      @id @default(cuid())
  description    String
  script         String?
  status         SceneStatus @default(PENDING)
  title          String?
  locationType   String?
  timeOfDay      String?
  weather        String?
  mood           String?
  lighting       String?
  colorPalette   String?
  setDressing    String?
  soundscape     String?
  cameraNotes    String?
  visualTags     String?
  artStyle       String?
  refImagePath   String?
  refGalleryJson String?
  looksJson      String?
  profileJson    String?
  seedPrompt     String?
  /** 生成鐵則：必須／禁止（場景板、氣氛、介紹片） */
  hardRules      String?
  locationKey    String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  storyLinks      StoryScene[]
  timelineEntries TimelineEntry[]
}

/** Global prop library asset. */
model Prop {
  id             String  @id @default(cuid())
  name           String
  description    String
  material       String?
  sizeNotes      String?
  condition      String?
  visualTags     String?
  artStyle       String?
  refImagePath   String?
  refGalleryJson String?
  profileJson    String?
  seedPrompt     String?
  /** 生成鐵則：必須／禁止（道具板、介紹片） */
  hardRules      String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  storyLinks      StoryProp[]
  timelineEntries TimelineEntry[]
}

/** Story selects characters (cast). */
model StoryCharacter {
  storyId     String
  characterId String
  sortOrder   Int     @default(0)
  roleNote    String?
  /** Optional wardrobe for this character in this story only. */
  costumeId   String?

  story     Story     @relation(fields: [storyId], references: [id], onDelete: Cascade)
  character Character @relation(fields: [characterId], references: [id], onDelete: Cascade)
  costume   Costume?  @relation(fields: [costumeId], references: [id], onDelete: SetNull)

  @@id([storyId, characterId])
}

/** Story selects scenes; sceneNumber is per-story order. */
model StoryScene {
  storyId        String
  sceneId        String
  sceneNumber    Int
  sortOrder      Int          @default(0)
  scriptOverride String?
  statusOverride SceneStatus?

  story Story @relation(fields: [storyId], references: [id], onDelete: Cascade)
  scene Scene @relation(fields: [sceneId], references: [id], onDelete: Cascade)

  @@id([storyId, sceneId])
  @@unique([storyId, sceneNumber])
}

model StoryProp {
  storyId   String
  propId    String
  sortOrder Int    @default(0)

  story Story @relation(fields: [storyId], references: [id], onDelete: Cascade)
  prop  Prop  @relation(fields: [propId], references: [id], onDelete: Cascade)

  @@id([storyId, propId])
}

/**
 * Global action / motion-direction library.
 * Multi-panel instruction plates + demo video; cast refs from other libraries.
 */
model Action {
  id             String   @id @default(cuid())
  name           String
  description    String
  /** Tempo, weight, body parts, effort */
  motionNotes    String?
  /** Intention / emotion / goal of the move */
  intention      String?
  /** Camera / blocking / staging */
  cameraNotes    String?
  /** grid-2x2 | strip-3 | strip-4 */
  panelLayout    String?
  visualTags     String?
  artStyle       String?
  refImagePath   String?
  refGalleryJson String?
  /** JSON: ActionCastRef[] from characters/costumes/scenes/props */
  castRefsJson   String?
  profileJson    String?
  seedPrompt     String?
  /** 生成鐵則：必須／禁止（動作分鏡板、介紹片） */
  hardRules      String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  storyLinks      StoryAction[]
  timelineEntries TimelineEntry[]
}

/** Story selects actions (motion library links). */
model StoryAction {
  storyId   String
  actionId  String
  sortOrder Int    @default(0)

  story  Story  @relation(fields: [storyId], references: [id], onDelete: Cascade)
  action Action @relation(fields: [actionId], references: [id], onDelete: Cascade)

  @@id([storyId, actionId])
}

model TimelineEntry {
  id          String      @id @default(cuid())
  storyId     String
  startTime   Float
  endTime     Float
  /** Primary character (first of characterIds); kept for FK + back-compat. */
  characterId String?
  sceneId     String?
  propId      String?
  actionId    String?
  /** JSON string arrays of linked cast ids, e.g. '["id1","id2"]'. */
  characterIds String?
  sceneIds     String?
  propIds      String?
  actionIds    String?
  /** Spoken-line cache (TTS/SRT); may be legacy free text. */
  dialogue    String?
  /** Structured beat screenplay JSON (BeatContent v1). */
  beatContentJson String?
  order       Int
  mediaPath   String?
  mediaStatus MediaStatus @default(EMPTY)
  mediaError  String?
  videoJobId  String?

  story     Story      @relation(fields: [storyId], references: [id], onDelete: Cascade)
  character Character? @relation(fields: [characterId], references: [id], onDelete: SetNull)
  scene     Scene?     @relation(fields: [sceneId], references: [id], onDelete: SetNull)
  prop      Prop?      @relation(fields: [propId], references: [id], onDelete: SetNull)
  action    Action?    @relation(fields: [actionId], references: [id], onDelete: SetNull)
}

enum StoryStatus {
  DRAFT
  GENERATING
  COMPLETED
  FAILED
}

enum SceneStatus {
  PENDING
  GENERATING
  COMPLETED
  FAILED
}

enum MediaStatus {
  EMPTY
  QUEUED
  GENERATING
  READY
  FAILED
}
