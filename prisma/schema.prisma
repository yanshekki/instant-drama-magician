generator client {
  provider = "prisma-client-js"
  output   = "../src/types/prisma"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model Story {
  id         String      @id @default(cuid())
  title      String
  status     StoryStatus @default(DRAFT)
  exportPath String?
  /** Visual / tone bible for clip prompt continuity */
  styleNote  String?
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt

  characters Character[]
  scenes     Scene[]
  props      Prop[]
  timeline   TimelineEntry[]
}

model Character {
  id           String  @id @default(cuid())
  storyId      String
  name         String
  soulMdPath   String?
  description  String
  refImagePath String?
  /** Detailed profile for short-drama + video consistency */
  appearance     String?
  personality    String?
  backstory      String?
  costume        String?
  ageRange       String?
  gender         String?
  voiceDesc      String?
  mannerisms     String?
  relationships  String?
  visualTags     String?
  seedPrompt     String?
  profileJson    String?
  refSheetPath   String?
  soulHubId      Int?

  story           Story           @relation(fields: [storyId], references: [id], onDelete: Cascade)
  timelineEntries TimelineEntry[]
}

model Scene {
  id          String      @id @default(cuid())
  storyId     String
  sceneNumber Int
  description String
  script      String?
  status      SceneStatus @default(PENDING)

  story           Story           @relation(fields: [storyId], references: [id], onDelete: Cascade)
  timelineEntries TimelineEntry[]
}

model Prop {
  id          String @id @default(cuid())
  storyId     String
  name        String
  description String

  story           Story           @relation(fields: [storyId], references: [id], onDelete: Cascade)
  timelineEntries TimelineEntry[]
}

model TimelineEntry {
  id          String      @id @default(cuid())
  storyId     String
  startTime   Float
  endTime     Float
  characterId String?
  sceneId     String?
  propId      String?
  dialogue    String?
  order       Int
  mediaPath   String?
  mediaStatus MediaStatus @default(EMPTY)
  mediaError  String?
  videoJobId  String?

  story     Story      @relation(fields: [storyId], references: [id], onDelete: Cascade)
  character Character? @relation(fields: [characterId], references: [id], onDelete: SetNull)
  scene     Scene?     @relation(fields: [sceneId], references: [id], onDelete: SetNull)
  prop      Prop?      @relation(fields: [propId], references: [id], onDelete: SetNull)
}

enum StoryStatus {
  DRAFT
  GENERATING
  COMPLETED
  FAILED
}

enum SceneStatus {
  PENDING
  GENERATING
  COMPLETED
  FAILED
}

enum MediaStatus {
  EMPTY
  QUEUED
  GENERATING
  READY
  FAILED
}
