{
  "name": "instant-drama-magician",
  "version": "1.0.0",
  "description": "AI 專業短劇生成桌面工具 — InstantDrama Magician",
  "main": "./out/main/index.js",
  "author": "yanshekki",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/yanshekki/instant-drama-magician.git"
  },
  "scripts": {
    "dev": "ELECTRON_DISABLE_SANDBOX=1 electron-vite dev -- --no-sandbox",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "typecheck": "tsc --noEmit -p tsconfig.node.json && tsc --noEmit -p tsconfig.web.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:studio": "prisma studio",
    "postinstall": "prisma generate",
    "pack": "npm run build && electron-builder --dir",
    "dist": "npm run build && electron-builder",
    "dist:linux": "npm run build && electron-builder --linux AppImage deb",
    "dist:win": "npm run build && electron-builder --win nsis",
    "dist:mac": "npm run build && electron-builder --mac dmg"
  },
  "build": {
    "appId": "hk.ysk.instant-drama-magician",
    "productName": "InstantDrama Magician",
    "directories": {
      "output": "release"
    },
    "files": [
      "out/**/*",
      "package.json",
      "node_modules/**/*",
      "src/types/prisma/**/*",
      "prisma/**/*"
    ],
    "asarUnpack": [
      "**/node_modules/ffmpeg-static/**",
      "**/node_modules/grok-cli-to-openai-compatible/**",
      "**/node_modules/.bin/gctoac"
    ],
    "publish": [
      {
        "provider": "github",
        "owner": "yanshekki",
        "repo": "instant-drama-magician"
      }
    ],
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "AudioVideo"
    },
    "mac": {
      "target": [
        "dmg"
      ],
      "category": "public.app-category.video",
      "identity": null
    },
    "win": {
      "target": [
        "nsis"
      ],
      "signAndEditExecutable": false
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "dependencies": {
    "@prisma/client": "^6.5.0",
    "electron-updater": "^6.8.9",
    "ffmpeg-static": "^5.3.0",
    "grok-cli-to-openai-compatible": "^1.5.2",
    "i18next": "^24.2.2",
    "jszip": "^3.10.1",
    "konva": "^9.3.20",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-i18next": "^15.4.1",
    "react-konva": "^18.2.10",
    "react-router-dom": "^7.2.0"
  },
  "devDependencies": {
    "@types/jszip": "^3.4.0",
    "@types/node": "^22.13.10",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "electron": "^34.3.0",
    "electron-builder": "^25.1.8",
    "electron-vite": "^3.0.0",
    "postcss": "^8.5.3",
    "prisma": "^6.5.0",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.8.2",
    "vite": "^6.2.0",
    "vitest": "^3.0.8"
  }
}
