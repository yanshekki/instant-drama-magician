# Grok-Cli-to-OpenAI-compatible (primary LLM)
# https://github.com/yanshekki/Grok-Cli-to-OpenAI-compatible
# Default port: 3847 (gctoac start)
GROK_CLI_BASE_URL=http://127.0.0.1:3847/v1
GROK_CLI_MODEL=grok-4.5
# Paste from Gateway Admin → Keys (gk_live_…)
GROK_CLI_API_KEY=

# Prefer in-app Settings (userData/settings.json) after first run.
# Video: POST {base}/videos — needs videoApi + agent/admin key
# See docs/grok-gateway.md

FFMPEG_PATH=ffmpeg
