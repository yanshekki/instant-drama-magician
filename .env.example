# Grok CLI OpenAI-compatible wrapper
# https://github.com/yanshekki/Grok-Cli-to-OpenAI-compatible
GROK_CLI_BASE_URL=http://127.0.0.1:39281/v1
GROK_CLI_MODEL=grok-cli
GROK_CLI_API_KEY=grok-cli

# Prefer in-app Settings (userData/settings.json) after first run.
# Video modes: auto | http | stub
# OpenAI-style videos: POST {base}/videos  (default http://127.0.0.1:39281/v1/videos)
# See docs/grok-gateway.md

FFMPEG_PATH=ffmpeg
